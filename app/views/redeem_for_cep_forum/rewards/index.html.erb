<% content_for :title do %>
  Rewards
<% end %>

<main class="cep-rewards" data-cep-rewards>
  <section class="cep-rewards__hero">
    <p class="cep-rewards__eyebrow">CEP Rewards</p>
    <h1>Rewards</h1>
    <p>领取论坛奖励兑换码，然后前往 CEP 前端「我的」页面兑换。</p>
  </section>

  <section class="cep-rewards__notice" data-cep-rewards-code hidden>
    <h2>兑换码</h2>
    <code data-cep-rewards-code-value></code>
    <p>兑换码只显示这一次。离开页面后不会再次展示，别拿自己的记忆力当数据库。</p>
  </section>

  <section class="cep-rewards__error" data-cep-rewards-error hidden></section>

  <section class="cep-rewards__grid" data-cep-rewards-list>
    <p>正在加载奖励...</p>
  </section>
</main>

<style>
  .cep-rewards {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .cep-rewards__hero {
    margin-bottom: 1.5rem;
  }

  .cep-rewards__eyebrow {
    color: var(--primary-medium);
    font-size: var(--font-down-1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cep-rewards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .cep-rewards__card,
  .cep-rewards__notice,
  .cep-rewards__error {
    border: 1px solid var(--primary-low);
    border-radius: 0.75rem;
    background: var(--secondary);
    box-shadow: 0 10px 30px rgb(var(--primary-rgb), 0.08);
  }

  .cep-rewards__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 190px;
    padding: 1.25rem;
  }

  .cep-rewards__card h2 {
    margin-top: 0;
  }

  .cep-rewards__days {
    display: inline-flex;
    margin-top: 0.5rem;
    color: var(--tertiary);
    font-weight: 700;
  }

  .cep-rewards__notice,
  .cep-rewards__error {
    margin-bottom: 1.25rem;
    padding: 1rem;
  }

  .cep-rewards__error {
    border-color: var(--danger-low);
    color: var(--danger);
  }

  .cep-rewards__notice code {
    display: block;
    margin: 0.75rem 0;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--primary-very-low);
    overflow-wrap: anywhere;
  }
</style>

<script nonce="<%= csp_nonce_placeholder %>">
  (() => {
    const root = document.querySelector("[data-cep-rewards]");

    if (!root) {
      return;
    }

    const list = root.querySelector("[data-cep-rewards-list]");
    const errorBox = root.querySelector("[data-cep-rewards-error]");
    const codeBox = root.querySelector("[data-cep-rewards-code]");
    const codeValue = root.querySelector("[data-cep-rewards-code-value]");

    function csrfToken() {
      return document.querySelector("meta[name='csrf-token']")?.content;
    }

    function showError(message) {
      errorBox.textContent = message;
      errorBox.hidden = false;
    }

    function clearError() {
      errorBox.textContent = "";
      errorBox.hidden = true;
    }

    function lockedText(reason) {
      if (reason === "claimed") {
        return "已领取";
      }

      if (reason === "cep_user_not_bound") {
        return "请先绑定 CEP 账号";
      }

      if (reason === "not_eligible") {
        return "暂未达成条件";
      }

      return "不可领取";
    }

    function renderRewards(rewards) {
      list.innerHTML = "";

      rewards.forEach((reward) => {
        const card = document.createElement("article");
        card.className = "cep-rewards__card";

        const content = document.createElement("div");
        const title = document.createElement("h2");
        const description = document.createElement("p");
        const days = document.createElement("span");

        title.textContent = reward.title;
        description.textContent = reward.description;
        days.className = "cep-rewards__days";
        days.textContent = `${reward.trial_days} 天`;

        content.append(title, description, days);

        const button = document.createElement("button");
        button.type = "button";
        button.className = reward.eligible && !reward.claimed ? "btn btn-primary" : "btn";

        if (reward.claimed || !reward.eligible) {
          button.disabled = true;
          button.textContent = lockedText(reward.locked_reason);
        } else {
          button.textContent = "领取";
          button.addEventListener("click", () => redeemReward(reward.key, button));
        }

        card.append(content, button);
        list.append(card);
      });
    }

    async function loadRewards() {
      clearError();

      const response = await fetch("/redeem-for-cep-forum/rewards.json", {
        credentials: "same-origin",
        headers: { Accept: "application/json" },
      });

      if (!response.ok) {
        throw new Error("奖励加载失败");
      }

      const payload = await response.json();
      renderRewards(payload.rewards || []);
    }

    async function redeemReward(rewardKey, button) {
      clearError();
      button.disabled = true;
      button.textContent = "领取中...";

      const response = await fetch(`/redeem-for-cep-forum/rewards/${rewardKey}/redeem.json`, {
        method: "POST",
        credentials: "same-origin",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
          "X-CSRF-Token": csrfToken(),
        },
      });

      const payload = await response.json();

      if (!response.ok) {
        showError(payload.errors?.join("，") || payload.error || "领取失败");
        await loadRewards();
        return;
      }

      codeValue.textContent = payload.code;
      codeBox.hidden = false;
      await loadRewards();
    }

    loadRewards().catch((error) => showError(error.message));
  })();
</script>
